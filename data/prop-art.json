{
  "props": {
    "flower": {
      "name": "Flower",
      "states": ["idle"],
      "setup": { "lineWidth": 1.5 },
      "animations": {
        "*": { "duration": 10472, "loop": true }
      },
      "shapes": [
        { "name": "Stem", "type": "lines", "stroke": true,
          "setup": { "strokeColor": "#5f8a4a", "lineWidth": 2 },
          "segments": [ [[0, 1.0], [0, 0]] ] },
        { "name": "Petals", "type": "group", "rotation": 0,
          "setup": { "fillColor": "#e88ab0", "alpha": 0.9, "shadowBlur": 4 },
          "anim": {
            "*": { "rotation": [ { "t": 0, "v": 0 }, { "t": 10472, "v": 6.283185, "ease": "linear" } ] }
          },
          "children": [
            { "type": "radialRepeat", "count": 6, "cx": 0, "cy": 0, "radius": 0,
              "children": [
                { "name": "petal", "type": "circle", "fill": true, "cx": 0, "cy": -0.5, "radiusAbs": 6 }
              ]
            }
          ]
        },
        { "name": "Center", "type": "circle", "fill": true, "cx": 0, "cy": 0, "radiusAbs": 5,
          "setup": { "fillColor": "#f2d14a", "shadowBlur": 6 } }
      ]
    },

    "rock": {
      "name": "Rock",
      "states": ["idle"],
      "setup": { "lineWidth": 1.5 },
      "shapes": [
        { "name": "Body", "type": "path", "fill": true, "stroke": true, "closed": true,
          "setup": { "fillColor": "#4a4f57", "strokeColor": "#2c3036", "shadowBlur": 3 },
          "points": [[-0.9, 0.5], [-0.5, -0.4], [0.2, -0.6], [0.85, -0.2], [0.8, 0.5]] },
        { "name": "Vein", "type": "lines", "stroke": true,
          "setup": { "strokeColor": "#6a7079", "alpha": 0.6 },
          "segments": [ [[-0.4, -0.1], [0.1, 0.2]], [[0.1, 0.2], [0.5, 0.0]] ] }
      ]
    },

    "sign": {
      "name": "Sign",
      "states": ["idle"],
      "setup": { "lineWidth": 1.5 },
      "shapes": [
        { "name": "Post", "type": "lines", "stroke": true,
          "setup": { "strokeColor": "#7a5a3a", "lineWidth": 3 },
          "segments": [ [[0, 1.0], [0, -0.2]] ] },
        { "name": "Board", "type": "rect", "fill": true, "stroke": true,
          "x": -0.6, "y": -0.6, "w": 1.2, "h": 0.65,
          "setup": { "fillColor": "#b98a4a", "strokeColor": "#6a4a28", "shadowBlur": 3 } }
      ]
    },

    "patLogo": {
      "name": "Pat_Engine Mark",
      "states": ["idle"],
      "setup": { "lineWidth": 4 },
      "animations": {
        "*": { "duration": 1600, "loop": true }
      },
      "shapes": [
        { "name": "Badge", "type": "circle", "fill": true, "cx": 0, "cy": 0, "radius": 1.0,
          "setup": { "fillColor": "#0b101c" } },
        { "name": "Ring", "type": "circle", "stroke": true, "cx": 0, "cy": 0, "radius": 0.94,
          "setup": { "strokeColor": "#d4a056", "lineWidth": 2.5, "alpha": 0.9, "shadowBlur": 8 } },
        { "name": "P stem", "type": "lines", "stroke": true,
          "setup": { "strokeColor": "#d4a056", "lineWidth": 4.5, "lineCap": "round", "shadowBlur": 5 },
          "segments": [ [[-0.34, -0.44], [-0.34, 0.44]] ] },
        { "name": "P bowl", "type": "arc", "stroke": true, "cx": -0.34, "cy": -0.21, "radius": 0.23,
          "startAngle": "-PI/2", "endAngle": "PI/2",
          "setup": { "strokeColor": "#d4a056", "lineWidth": 4.5, "lineCap": "round", "shadowBlur": 5 } },
        { "name": "Cursor", "type": "rect", "fill": true,
          "x": 0.02, "y": 0.32, "w": 0.42, "h": 0.11,
          "setup": { "fillColor": "#d4a056", "shadowBlur": 7 },
          "anim": {
            "*": {
              "setup.alpha": [
                { "t": 0, "v": 1 }, { "t": 700, "v": 1 }, { "t": 800, "v": 0.15 },
                { "t": 1500, "v": 0.15 }, { "t": 1600, "v": 1 }
              ]
            }
          } },
        { "name": "Keyframe diamond", "type": "path", "fill": true, "closed": true,
          "setup": { "fillColor": "#33ddcc", "shadowBlur": 6 },
          "points": [[0.34, -0.38], [0.46, -0.24], [0.34, -0.10], [0.22, -0.24]],
          "anim": {
            "*": {
              "setup.alpha": [
                { "t": 0, "v": 0.75 }, { "t": 800, "v": 1, "ease": "easeInOutSine" }, { "t": 1600, "v": 0.75, "ease": "easeInOutSine" }
              ]
            }
          } }
      ]
    },

    "logo": {
      "name": "Garden Emblem",
      "states": ["idle"],
      "setup": { "lineWidth": 2 },
      "animations": {
        "*": { "duration": 3927, "loop": true }
      },
      "shapes": [
        { "name": "Pulse ring", "type": "circle", "stroke": true, "cx": 0, "cy": 0,
          "radiusAbs": { "base": 30 },
          "setup": { "strokeColor": "#7cc6a0", "alpha": 0.5, "shadowBlur": 8 },
          "anim": {
            "*": {
              "radiusAbs": [ { "t": 0, "v": { "base": 30 } }, { "t": 1963, "v": { "base": 36 }, "ease": "easeInOutSine" }, { "t": 3927, "v": { "base": 30 }, "ease": "easeInOutSine" } ],
              "setup.alpha": [ { "t": 0, "v": 0.5 }, { "t": 1963, "v": 0.8, "ease": "easeInOutSine" }, { "t": 3927, "v": 0.5, "ease": "easeInOutSine" } ],
              "setup.shadowBlur": [ { "t": 0, "v": 8 }, { "t": 1963, "v": 18, "ease": "easeInOutSine" }, { "t": 3927, "v": 8, "ease": "easeInOutSine" } ]
            }
          }
        },
        { "name": "Arc upper", "type": "arc", "stroke": true, "cx": 0, "cy": 0, "radius": 0.6,
          "startAngle": "-PI*0.85", "endAngle": "-PI*0.15",
          "setup": { "strokeColor": "#cad27a", "lineWidth": 3 } },
        { "name": "Sprout", "type": "path", "stroke": true, "closed": false,
          "setup": { "strokeColor": "#7cc6a0", "lineWidth": 3 },
          "points": [[0, 0.5], [0, -0.2], [-0.35, -0.45]] },
        { "name": "Bud", "type": "circle", "fill": true, "cx": -0.35, "cy": -0.45, "radiusAbs": 6,
          "setup": { "fillColor": "#e88ab0", "shadowBlur": 6 } }
      ]
    }
  }
}
