{
  "critters": {
    "blob": {
      "name": "Blob",
      "states": ["idle", "happy", "scared"],
      "setup": { "lineWidth": 2 },
      "transitionDuration": 150,
      "animations": {
        "*": { "duration": 3142, "loop": true },
        "happy": { "duration": 3142, "loop": true }
      },
      "shapes": [
        { "name": "Glow", "type": "circle", "fill": true, "cx": 0, "cy": 0,
          "radiusAbs": { "base": 18 },
          "setup": { "alpha": 0.12, "shadowBlur": 8 },
          "anim": {
            "*": {
              "radiusAbs": [ { "t": 0, "v": { "base": 18 } }, { "t": 1571, "v": { "base": 24 }, "ease": "easeInOutSine" }, { "t": 3142, "v": { "base": 18 }, "ease": "easeInOutSine" } ],
              "setup.alpha": [ { "t": 0, "v": 0.12 }, { "t": 1571, "v": 0.22, "ease": "easeInOutSine" }, { "t": 3142, "v": 0.12, "ease": "easeInOutSine" } ],
              "setup.shadowBlur": [ { "t": 0, "v": 8 }, { "t": 1571, "v": 16, "ease": "easeInOutSine" }, { "t": 3142, "v": 8, "ease": "easeInOutSine" } ]
            },
            "happy": {
              "setup.alpha": [ { "t": 0, "v": 0.28 }, { "t": 1571, "v": 0.44, "ease": "easeInOutSine" }, { "t": 3142, "v": 0.28, "ease": "easeInOutSine" } ]
            }
          }
        },
        { "name": "Body", "type": "circle", "fill": true, "stroke": true, "cx": 0, "cy": 0, "radius": 0.72,
          "setup": { "shadowBlur": 4 },
          "states": {
            "happy": { "setup": { "shadowBlur": 12 } },
            "scared": { "setup": { "shadowBlur": 1 } }
          }
        },
        { "name": "Eye L", "type": "circle", "fill": true, "cx": -0.26, "cy": -0.12, "radiusAbs": 3,
          "setup": { "fillColor": "#101820" } },
        { "name": "Eye R", "type": "circle", "fill": true, "cx": 0.26, "cy": -0.12, "radiusAbs": 3,
          "setup": { "fillColor": "#101820" } },
        { "name": "Brow", "type": "lines", "stroke": true, "visibleStates": ["scared"],
          "setup": { "lineWidth": 2, "strokeColor": "#101820" },
          "segments": [ [[-0.38, -0.34], [-0.14, -0.26]], [[0.38, -0.34], [0.14, -0.26]] ] },
        { "name": "Mouth", "type": "path", "stroke": true, "closed": false,
          "setup": { "lineWidth": 2, "strokeColor": "#101820" },
          "points": [[-0.2, 0.24], [0, 0.32], [0.2, 0.24]],
          "states": { "scared": { "points": [[-0.2, 0.32], [0, 0.24], [0.2, 0.32]] } } },
        { "name": "Sparkle", "type": "group", "visibleStates": ["happy"], "rotation": 0,
          "setup": { "strokeColor": "#fff7d8", "alpha": 0.9, "lineWidth": 1.5, "shadowBlur": 6 },
          "anim": {
            "happy": { "rotation": [ { "t": 0, "v": 0 }, { "t": 3142, "v": 62.831853, "ease": "linear" } ] }
          },
          "children": [
            { "type": "radialRepeat", "count": 5, "cx": 0, "cy": 0, "radius": 0,
              "children": [
                { "name": "ray", "type": "lines", "stroke": true, "segments": [ [[0, -0.95], [0, -1.15]] ] }
              ]
            }
          ]
        }
      ]
    },

    "sprout": {
      "name": "Sprout",
