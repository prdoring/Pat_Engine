            { "name": "Spot L", "type": "circle", "fill": true, "cx": -0.28, "cy": 0.06, "radiusAbs": 3, "setup": { "fillColor": "#3a5f3a" } },
            { "name": "Spot R", "type": "circle", "fill": true, "cx": 0.28, "cy": 0.06, "radiusAbs": 3, "setup": { "fillColor": "#3a5f3a" } },
            { "name": "Head", "type": "circle", "fill": true, "cx": 0, "cy": -0.5, "radiusAbs": 9, "setup": { "fillColor": "#4f7f4f", "shadowBlur": 2 } },
